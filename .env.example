NODE_ENV=development
PORT=8080

# Supabase project settings.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Protect admin/test API routes such as GET /api/calls and PATCH /api/calls/:id.
# Leave empty only for local development.
ADMIN_API_SECRET=change-me-admin-secret

# LGU+ Centrex settings. Keep the password hash, not the plain password.
LGU_PRODUCT_TYPE=centrex
LGU_BASE_URL=https://centrex.uplus.co.kr/RestApi
LGU_ID=07012345678
LGU_PASS_HASH=sha512-password-hash

# Secret used by LGU+ callback URL:
# http://YOUR_STATIC_IP/lgu/ring.html?secret=...
LGU_WEBHOOK_SECRET=change-me-webhook-secret

# Secret used by cron:
# curl -X POST "http://localhost:8080/api/lgu/sync?secret=..."
SYNC_SECRET=change-me-sync-secret
